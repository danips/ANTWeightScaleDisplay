<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#333333"
            app:cardElevation="4dp"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iconWeight"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:padding="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:srcCompat="@drawable/ic_weight"
                    android:background="@drawable/rounded_green"/>

                <TextView
                    android:id="@+id/weightTV"
                    tools:text="73.80 kg"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/iconWeight"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/labelBMI"
                    android:text="@string/weight_fragment_bmi_tag"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/iconWeight"
                    app:layout_constraintTop_toBottomOf="@id/weightTV" />
                <TextView
                    android:id="@+id/bmiTV"
                    tools:text="23.03"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/labelBMI"
                    app:layout_constraintTop_toBottomOf="@id/weightTV"/>
                <TextView
                    android:id="@+id/bmiDescTV"
                    tools:text="Normal"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/bmiTV"
                    app:layout_constraintTop_toBottomOf="@id/weightTV"/>

                <ImageView
                    android:id="@+id/weightIVmini"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:srcCompat="@drawable/ic_equal"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSegmentalContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#333333"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardWeight">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/segmentalData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/item_segment"
                    android:id="@+id/segLeftArm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintWidth_percent="0.33"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/segTrunk"
                    app:layout_constraintHorizontal_chainStyle="spread"/>

                <include layout="@layout/item_segment"
                    android:id="@+id/segLeftLeg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="@+id/segLeftArm"
                    app:layout_constraintEnd_toEndOf="@+id/segLeftArm"
                    app:layout_constraintTop_toBottomOf="@+id/segLeftArm"/>

                <include layout="@layout/item_segment"
                    android:id="@+id/segTrunk"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintWidth_percent="0.33"
                    app:layout_constraintStart_toEndOf="@+id/segLeftArm"
                    app:layout_constraintEnd_toStartOf="@+id/segRightArm"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <include layout="@layout/item_segment"
                    android:id="@+id/segRightArm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintWidth_percent="0.33"
                    app:layout_constraintStart_toEndOf="@+id/segTrunk"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <include layout="@layout/item_segment"
                    android:id="@+id/segRightLeg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="@+id/segRightArm"
                    app:layout_constraintEnd_toEndOf="@+id/segRightArm"
                    app:layout_constraintTop_toBottomOf="@+id/segRightArm"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>


        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="2"
            android:rowCount="4"
            android:alignmentMode="alignMargins"
            app:layout_constraintTop_toBottomOf="@id/cardSegmentalContainer">

            <include layout="@layout/item_metric_card"
                android:id="@+id/cardFat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="8dp"
                android:layout_marginLeft="0dp"/>

            <include layout="@layout/item_metric_card"
                android:id="@+id/cardWater"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="8dp"
                android:layout_marginRight="0dp"/>

            <include layout="@layout/item_metric_card"
                android:id="@+id/cardMuscle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="8dp"
                android:layout_marginLeft="0dp"/>

            <include layout="@layout/item_metric_card"
                android:id="@+id/cardBone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="8dp"
                android:layout_marginRight="0dp"/>

            <include layout="@layout/item_metric_card"
                android:id="@+id/cardVisceral"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="8dp"
                android:layout_marginLeft="0dp"/>

            <include layout="@layout/item_metric_card"
                android:id="@+id/cardPhysique"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="8dp"
                android:layout_marginRight="0dp"/>

            <include layout="@layout/item_metric_card"
                android:id="@+id/cardMetabolicAge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="8dp"
                android:layout_marginLeft="0dp"/>

            <include layout="@layout/item_metric_card"
                android:id="@+id/cardBMR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="8dp"
                android:layout_marginRight="0dp"/>

        </GridLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:srcCompat="@android:drawable/ic_input_add"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>