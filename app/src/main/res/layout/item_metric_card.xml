<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#333333"
    app:contentPadding="12dp"
    app:contentPaddingTop="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/metricTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:minLines="1"
            android:textColor="#DDDDDD"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAlignment="textEnd"
            tools:text="Body Fat" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/metricIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="10dp"
                tools:src="@drawable/ic_metabolic"
                tools:background="@drawable/rounded_blue"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/metricValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="18.70 %"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>

                <TextView
                    android:id="@+id/metricSubValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Healthy"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"
                    android:visibility="visible"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/metricTrend"
                android:layout_width="16dp"
                android:layout_height="16dp"
                tools:src="@drawable/ic_equal" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>