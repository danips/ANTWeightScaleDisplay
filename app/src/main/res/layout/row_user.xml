<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ll_user"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/selectableItemBackground"
        android:minHeight="72dp"
        android:padding="12dp">

        <ImageView
            android:id="@+id/userIV"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/edit_user_fragment_user"
            android:padding="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_action_person" />

        <TextView
            android:id="@+id/nameTV"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/connections"
            app:layout_constraintStart_toEndOf="@id/userIV"
            app:layout_constraintTop_toTopOf="@id/userIV"
            tools:text="Alex" />

        <TextView
            android:id="@+id/descTV"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/userIV"
            app:layout_constraintTop_toBottomOf="@id/nameTV"
            tools:text="34 years · 180 cm" />

        <LinearLayout
            android:id="@+id/connections"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/userIV">

            <ImageView
                android:id="@+id/gcIV"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/edit_user_fragment_garmin_connect_category"
                android:padding="3dp"
                app:srcCompat="@drawable/ic_gc" />

            <ImageView
                android:id="@+id/emailIV"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/edit_user_fragment_email_category"
                android:padding="3dp"
                app:srcCompat="@drawable/ic_gmail" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
